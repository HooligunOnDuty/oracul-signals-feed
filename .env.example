# ── Vercel (set in Vercel dashboard → Settings → Environment Variables) ──
INGEST_SECRET=generate-a-long-random-string-here
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# ── Local sync script only (project ROOT — not app/) ──
AGENT_DASHBOARD_URL=http://127.0.0.1:3847
# Use production URL — preview URLs (git-main-....vercel.app) often require login
VERCEL_INGEST_URL=https://your-app.vercel.app/api/ingest
INGEST_SECRET=same-as-vercel
# Optional: only if you must hit a protected preview URL
# VERCEL_PROTECTION_BYPASS=from-vercel-deployment-protection-settings
SYNC_INTERVAL_MS=15000
